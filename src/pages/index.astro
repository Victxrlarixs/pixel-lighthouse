---
// Lighthouse Pixel — Performance Site Telemetry
import '../styles/global.css';
import Preloader from '../components/Preloader.astro';
import ThemeSwitch from '../components/ThemeSwitch.astro';
import TelemetryHUD from '../components/TelemetryHUD.astro';
import Simulator from '../components/Simulator.astro';
import Console from '../components/Console.astro';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Lighthouse Pixel - Performance Site Telemetry</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect x='8' y='4' width='16' height='24' fill='%231a1b26' stroke='%2324283b' stroke-width='2'/><rect x='10' y='8' width='12' height='2' fill='%230f111a'/><circle cx='12' cy='9' r='1' fill='%239ece6a'/><rect x='10' y='14' width='12' height='2' fill='%230f111a'/><circle cx='18' cy='15' r='1' fill='%23f7768e'/><rect x='10' y='20' width='12' height='2' fill='%230f111a'/><circle cx='15' cy='21' r='1' fill='%237aa2f7'/></svg>" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
  <Preloader />
  
  <div class="crt-overlay"></div>

  <ThemeSwitch />

  <div class="app-container">
    <div class="simulation-view">
      <canvas id="simulation-canvas"></canvas>
      
      <TelemetryHUD />
      <Simulator />
    </div>

    <Console />
  </div>

  <script src="../client/main.ts"></script>
</body>
</html>
