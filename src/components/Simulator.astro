---
// Simulator.astro — Scenario Simulator (RESTORING ORIGINAL UI)
---
<button class="btn-toggle-sim" id="btn-toggle-sim" title="Toggle Scenario Simulator">
  <i class="fas fa-server"></i>
</button>

<div class="floating-simulator hidden" id="floating-simulator">
  <div class="sim-header">
    <i class="fas fa-flask"></i>
    <span>SCENARIO_SIMULATOR</span>
  </div>
  <div class="sim-control">
    <input type="range" id="sim-score" min="0" max="100" value="95" />
    <span id="sim-val" class="sim-badge">95</span>
  </div>
</div>
