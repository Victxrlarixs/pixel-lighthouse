---
// ThemeSwitch.astro — Night mode toggle (RESTORING ORIGINAL UI)
---
<div class="switch-container">
  <label class="switch">
    <input type="checkbox" id="night-toggle" />
    <span class="slider">
      <i class="fas fa-sun switch-icon sun"></i>
      <i class="fas fa-moon switch-icon moon"></i>
    </span>
  </label>
</div>
